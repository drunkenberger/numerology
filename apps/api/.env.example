# ── Anthropic ────────────────────────────────────────────────────────────────
# NUNCA expongas esta clave al cliente móvil
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ─────────────────────────────────────────────────────────────────
# Service role key — solo para el backend (tiene acceso total, bypassea RLS)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── RevenueCat ───────────────────────────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=whsec_...

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Máximo de lecturas generadas por usuario premium por hora
RATE_LIMIT_READINGS_PER_HOUR=20
