# apps/mobile/.env
# Copiar como .env y completar con tus valores reales

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # anon key (NO service_role)
EXPO_PUBLIC_API_URL=http://localhost:3000

# RevenueCat — crear app en revenuecat.com y obtener las keys de cada plataforma
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...
